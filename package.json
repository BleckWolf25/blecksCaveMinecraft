{
  "name": "bleckcaveminecraft",
  "version": "1.0.0",
  "description": "Bleck's Minecraft Projects in one place.",
  "author": "João Costa <joao.coutinho08@gmail.com>",
  "license": "MIT",
  "homepage": "https://bleckscavemc.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BleckWolf25/bleckcaveminecraft.git"
  },
  "bugs": {
    "url": "https://github.com/BleckWolf25/bleckcaveminecraft/issues"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/prerender.ts",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test:coverage": "vitest --coverage",
    "prepare": "husky",
    "precommit": "pnpm -s lint-staged",
    "prepush": "pnpm run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "marked": "^18.0.6"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
